{
  "name": "ios-android-refactor-tool",
  "version": "2.0.0",
  "description": "iOS/Android 项目重构工具 - 批量替换类前缀和包名",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:dmg": "electron-builder --mac dmg"
  },
  "keywords": ["electron", "swift", "android", "kotlin", "java", "rename", "prefix", "package"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.refactortool.app",
    "productName": "iOS Android Refactor Tool",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "zip",
          "arch": ["x64", "arm64"]
        }
      ],
      "darkModeSupport": true
    },
    "dmg": {
      "title": "iOS/Android Refactor Tool",
      "window": {
        "width": 600,
        "height": 400
      },
      "contents": [
        {
          "x": 150,
          "y": 180,
          "type": "file"
        },
        {
          "x": 450,
          "y": 180,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "files": [
      "main.js",
      "renderer.js",
      "index.html",
      "styles.css"
    ],
    "directories": {
      "output": "dist"
    }
  }
}
